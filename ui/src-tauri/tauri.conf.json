{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Operant",
  "version": "1.1.0",
  "identifier": "dev.operant.shell",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Operant",
        "width": 1024,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "transparent": true,
        "windowEffects": {
          "effects": ["mica"]
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "externalBin": ["binaries/operant"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "installMode": "both",
        "installerHooks": "../../release/nsis/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG9wZXJhbnQgdXBkYXRlciBwdWJsaWMga2V5IDhCRTRCOTQ3QjE1NjZCN0MKUldTTDVMbEhzVlpyZkJ1ZG5jeU5ZaFBUMDNZYStpV2dPSWdpZWxpOVMxVHk3YWJVWjBCdCtzTnAK",
      "endpoints": [
        "https://github.com/AlpharomeroJL/operant/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
