{
  "name": "operant-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Operant C13 shell UI and C19 zero-code design system: design tokens, default/Advanced mode switch, and a mocked event bus so the shell renders with no backend running.",
  "scripts": {
    "predev": "npm run build:tokens",
    "dev": "vite",
    "prebuild": "npm run build:tokens",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "npm run build:tokens",
    "test": "node --import ./src/styles/testHooks.mjs --test",
    "typecheck": "tsc --noEmit",
    "build:tokens": "node scripts/build-tokens.mjs"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.4"
  }
}
