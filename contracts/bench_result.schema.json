{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://operant.dev/contracts/bench_result.schema.json",
  "title": "Bench Result",
  "description": "One row of benchmark output: one task in one mode. A bench run emits an array of these; the BENCHMARKS.md renderer consumes the array.",
  "type": "object",
  "required": ["v", "suite", "task", "mode", "repetitions", "successes", "p50_step_ms", "p95_step_ms", "total_wall_ms", "model_calls", "tokens"],
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "suite": { "type": "string" },
    "task": { "type": "string" },
    "mode": { "type": "string", "enum": ["replay", "reinfer_mock", "reinfer_real"] },
    "repetitions": { "type": "integer", "minimum": 1 },
    "successes": { "type": "integer", "minimum": 0 },
    "p50_step_ms": { "type": "number", "minimum": 0 },
    "p95_step_ms": { "type": "number", "minimum": 0 },
    "total_wall_ms": { "type": "number", "minimum": 0 },
    "model_calls": { "type": "integer", "minimum": 0, "description": "0 for replay by construction." },
    "tokens": { "type": "integer", "minimum": 0, "description": "0 for replay by construction." },
    "notes": { "type": "string" },
    "ts": { "type": "string", "description": "ISO 8601 timestamp of the run." }
  },
  "additionalProperties": false
}
